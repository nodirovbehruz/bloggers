# Blogger Awards - Environment Configuration

# Application
APP_NAME=Blogger Awards API
APP_VERSION=1.0.0
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/blogger_awards

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMS (Eskiz)
SMS_PROVIDER=eskiz
SMS_API_KEY=your_eskiz_api_key
SMS_API_URL=https://notify.eskiz.uz/api

# Contest
CONTEST_START_DATE=2026-03-01T00:00:00
CONTEST_END_DATE=2026-04-15T00:00:00
DAILY_VOTE_LIMIT=1
VIP_VOTE_PRICE=10000

# Security
IP_VOTE_LIMIT=10
DEVICE_LIMIT=3
RATE_LIMIT_PER_MINUTE=30

# Payments
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
